# Symphony environment variables.
# Copy this file to .env (it will be ignored by git) and fill in the values.
#
# Place this file in either:
#   - the directory containing your WORKFLOW.md (preferred), or
#   - the directory from which you launch `symphony`
#
# Shell-exported variables always win over .env values.

# GitHub personal access token used by tracker.api_key: $GITHUB_TOKEN
# Minimum scopes: issues:read, pull_requests:read.
# Add issues:write / pull_requests:write / contents:write if the agent should mutate.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Claude Code credentials (forwarded to the subprocess).
# Skip if you've already authenticated via `claude login` or Bedrock/Vertex creds.
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: change the dashboard bind address.
# SYMPHONY_HOST=127.0.0.1
# SYMPHONY_PORT=4747

# Optional: log verbosity (debug|info|warn|error).
# SYMPHONY_LOG_LEVEL=info
